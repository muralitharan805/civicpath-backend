generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model assembly_constituencies {
  ogc_fid    Int                      @id @default(autoincrement())
  objectid   Decimal?                 @db.Decimal(9, 0)
  st_code    Decimal?                 @db.Decimal(10, 0)
  st_name    String?                  @db.VarChar(254)
  dt_code    Decimal?                 @db.Decimal(10, 0)
  dist_name  String?                  @db.VarChar(254)
  ac_no      Decimal?                 @db.Decimal(10, 0)
  ac_name    String?                  @db.VarChar(254)
  pc_no      Decimal?                 @db.Decimal(10, 0)
  pc_name    String?                  @db.VarChar(254)
  pc_id      Decimal?                 @db.Decimal(10, 0)
  status     String?                  @db.VarChar(254)
  shape_leng Decimal?                 @db.Decimal(18, 11)
  shape_area Decimal?                 @db.Decimal(18, 11)
  geom       Unsupported("geometry")?

  @@index([geom], map: "assembly_constituencies_geom_geom_idx", type: Gist)
}

model parliment_constituencies {
  ogc_fid Int                      @id @default(autoincrement())
  st_name String?                  @db.VarChar(254)
  pc_name String?                  @db.VarChar(254)
  st_code String?                  @db.VarChar(3)
  pc_code Decimal?                 @db.Decimal(4, 0)
  res     String?                  @db.VarChar(4)
  geom    Unsupported("geometry")?

  @@index([geom], map: "parliment_constituencies_geom_geom_idx", type: Gist)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}
